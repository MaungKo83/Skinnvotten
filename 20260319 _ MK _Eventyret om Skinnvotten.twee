:: StoryScript [script]
// ================================
// SAFE JS for Harlowe navigation
// ================================
setInterval(() => {
    const sidebar = document.querySelector("tw-sidebar");
    if (!sidebar) return;

    // BACK ARROW always safe
    const back = sidebar.querySelector('tw-icon[alt="back"]');
    if (back) {
        back.style.cursor = "pointer";
        back.onclick = () => {
            try { Engine.goBack(); } catch(e) { console.warn("Back failed", e); }
        };
    }

    // FORWARD ARROW — only safe if a forward link exists
    const forward = sidebar.querySelector('tw-icon[alt="forward"]');
    if (forward) {
        forward.style.cursor = "pointer";
        forward.onclick = () => {
            // In Harlowe, do not force goForward unless a previous goBack exists
            const hist = Engine.history;
            const last = hist ? hist[hist.length-1] : null;
            if (last && last.forward) {
                try { Engine.goForward(); } catch(e) { console.warn("Forward failed", e); }
            } else {
                console.warn("No forward available — cannot navigate safely.");
            }
        };
    }
}, 100);




// Run once when the story first loads
function addFooter() {
    if (!document.getElementById("footer")) {
        const footer = document.createElement("div");
        footer.id = "footer";
        footer.innerHTML =
            "© Opphavsrett<br>© 2026 Maung Ko<br>Laget for læring og demonstrasjon av twine.";
        document.querySelector("tw-story").appendChild(footer);
    }
}

// Add footer on start
setTimeout(addFooter, 0);

// Add footer every time a passage changes
document.addEventListener("transitionend", addFooter);



:: StoryStylesheet [stylesheet]
/* ================================
   FONT
================================ */
@import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap');


/* ================================
   BACKGROUND
================================ */
tw-story {
  position: relative;
  min-height: 100vh;
  background-image: url("images/bg.jpg");
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  font-family: 'Open Sans', sans-serif;
  color: white;
}


tw-story {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow-y: scroll;
}



/* dark overlay */
tw-story::before {
  content:"";
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.65);
  z-index:-1;
}


/* ================================
   CENTER STORY BOX
================================ */
tw-passage {
  max-width: 800px;
  margin: 40px auto;
  padding: 30px;
  background: rgba(0,0,0,0.65);
  border-radius: 15px;
  box-shadow: 0 0 25px rgba(0,0,0,0.8);
  line-height: 1.6;
  font-size: 1.1em;
}


/* ================================
   HEADINGS
================================ */
h1 {
  text-align:center;
  font-size:2.2em;
  color:#4fc3f7;
}

h2 {
  color:#81d4fa;
}

h3 {
  color:#b3e5fc;
}


/* ================================
   LINKS (CHOICES)
================================ */
tw-link {
 text-align: center !important;
  display: block !important;
  margin-left: auto !important;
  margin-right: auto !important;
  background:rgba(79,195,247,0.15);
  border-left:4px solid #4fc3f7;
  border-radius:8px;
  color:white;
  text-decoration:none;
  transition:0.2s;
}



tw-link:hover {
  background:rgba(79,195,247,0.35);
  transform:translateX(5px);
}


/* ================================
   BUTTON STYLE
================================ */
button {
  background:#4fc3f7;
  border:none;
  padding:10px 18px;
  border-radius:8px;
  color:white;
  font-weight:600;
  cursor:pointer;
}

button:hover {
  background:#29b6f6;
}


/* ================================
   IMAGES IN STORY
================================ */
tw-passage img {
  width:100%;
  border-radius:10px;
  margin:15px 0;
  box-shadow:0 0 10px black;
}


/* ================================
   SIDEBAR
================================ */
tw-sidebar {
  background: rgba(0,0,0,0.5);
  border-radius:10px;
  padding:10px;
}

/* arrows */
tw-sidebar tw-icon {
  font-size:2em;
  filter: drop-shadow(0 0 5px black);
}


/* ================================
   INVENTORY BOX (optional)
================================ */
.inventory {
  background:rgba(255,255,255,0.1);
  padding:10px;
  border-radius:10px;
  margin-top:15px;
}


/* ================================
   MOBILE
================================ */
@media (max-width: 600px) {
  tw-passage {
    margin:10px;
    padding:20px;
  }

  h1 {
    font-size:1.6em;
  }
}



#footer {
    position: fixed;
    bottom: 5px; /* moves footer down */
    left: 50%;
    transform: translateX(-50%);
    
    background: rgba(0, 0, 0, 0.50); /* softer transparency */
    color: #ffffff;
    
    padding: 4px 12px;    /* smaller footer */
    font-size: 12px;      /* smaller text */
    line-height: 1.3em;
    
    border-radius: 6px;
    text-align: center;
    
    z-index: 99999;
    pointer-events: none; /* IMPORTANT: footer no longer blocks clicks */
}